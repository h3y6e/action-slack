{
  "name": "action-slack",
  "version": "4.0.8",
  "description": "You can notify slack of GitHub Actions.",
  "keywords": [
    "actions",
    "chat",
    "node",
    "setup",
    "slack"
  ],
  "license": "MIT",
  "author": "h3y6e",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h3y6e/action-slack.git"
  },
  "type": "module",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint --type-aware --max-warnings=0",
    "lint:fix": "oxlint --type-aware --fix-dangerously",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@slack/webhook": "^7.0.7",
    "https-proxy-agent": "^8.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.5",
    "msw": "2.14.5",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.17.1",
    "tsdown": "0.22.0",
    "typescript": "5.9.3",
    "undici": "7.24.5",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
